# ─────────────────────────────────────────────────────────────────────────────
# Dinner Scheduler — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# 
# Copy this file to .env for local development (never commit .env to git!)
# These same variables must be set in Railway's environment settings.
#
# All GOOGLE_* values come from your Google Cloud Service Account JSON key file.
# See SETUP.md for step-by-step instructions.
# ─────────────────────────────────────────────────────────────────────────────

# The Google Calendar to populate (your Gmail address)
CALENDAR_ID=jloucks0@gmail.com

# Google Service Account credentials (from the downloaded JSON key file)
GOOGLE_PROJECT_ID=your-project-id
GOOGLE_PRIVATE_KEY_ID=your-private-key-id
GOOGLE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nyour-private-key-here\n-----END RSA PRIVATE KEY-----\n"
GOOGLE_CLIENT_EMAIL=dinner-scheduler@your-project-id.iam.gserviceaccount.com
GOOGLE_CLIENT_ID=123456789012345678901
